# MoltAgent Environment Configuration
# Copy this file to .env and customize values for your deployment
# All values shown are defaults (except secrets which must be set)

# =============================================================================
# REQUIRED - Must be set for the application to work
# =============================================================================

# Nextcloud Talk webhook secret (for signature verification)
NC_TALK_SECRET=your-webhook-secret-here

# Nextcloud credentials - use ONE of the following methods:
# Option 1: Direct password (not recommended for production)
# NC_PASSWORD=your-app-password
# Option 2: Credential file path
# NC_CREDENTIAL_FILE=/path/to/credential/file
# Option 3: systemd credential (recommended for production)
# CREDENTIALS_DIRECTORY=/run/credentials/moltagent.service

# =============================================================================
# NEXTCLOUD CONNECTION
# =============================================================================

# Nextcloud base URL
NC_URL=https://your-nextcloud-instance.com

# Nextcloud username for API calls
NC_USER=moltagent

# Primary Talk room for proactive messages (daily digest, meeting prep, alerts).
# This is the default room when no specific room is targeted.
# Create this room in NC Talk and add the bot user, then paste its token here.
TALK_PRIMARY_ROOM=your-primary-room-token

# Legacy aliases (still work, TALK_PRIMARY_ROOM takes precedence):
# TALK_ROOM_TOKEN=your-room-token
# NC_TALK_DEFAULT_TOKEN=your-room-token

# Allowed webhook backend URLs (comma-separated, defaults to NC_URL)
# NC_TALK_BACKENDS=https://nc1.example.com,https://nc2.example.com

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Ollama API endpoint
OLLAMA_URL=http://localhost:11434

# Default Ollama model
OLLAMA_MODEL=deepseek-r1:8b

# Credential-dedicated Ollama model (heavier, for sensitive ops; falls back to OLLAMA_MODEL)
OLLAMA_MODEL_CREDENTIAL=qwen3:14b-fast

# Ollama request timeout in ms (covers cold start + inference; default 5 min)
OLLAMA_TIMEOUT=300000

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# HTTP server port
PORT=3000

# Bind host (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# =============================================================================
# SECURITY
# =============================================================================

# Enable strict mode for signature verification
STRICT_MODE=true

# Enable debug logging (disable in production)
DEBUG_MODE=false

# =============================================================================
# TIMEOUTS (milliseconds)
# =============================================================================

# General HTTP request timeout
TIMEOUT_HTTP_REQUEST=30000

# Ollama health check timeout
TIMEOUT_OLLAMA_HEALTH=5000

# Deck API request timeout
TIMEOUT_DECK_API=30000

# IMAP connection timeout
TIMEOUT_IMAP=30000

# SMTP connection timeout
TIMEOUT_SMTP=30000

# Graceful shutdown timeout
TIMEOUT_SHUTDOWN=30000

# =============================================================================
# NEXTCLOUD REQUEST MANAGER (Rate Limiting)
# =============================================================================

# Max concurrent requests to Nextcloud
NC_MAX_CONCURRENT=4

# Default retry delay on 429 (ms)
NC_RETRY_AFTER=30000

# Max request queue size
NC_MAX_QUEUE=1000

# Max retries for failed requests
NC_MAX_RETRIES=3

# =============================================================================
# CACHE TTLs (milliseconds)
# =============================================================================

# NC Passwords API cache
CACHE_TTL_PASSWORDS=300000

# CalDAV cache
CACHE_TTL_CALDAV=60000

# Deck API cache
CACHE_TTL_DECK=30000

# WebDAV cache
CACHE_TTL_WEBDAV=30000

# Talk API cache
CACHE_TTL_TALK=5000

# OCS API cache
CACHE_TTL_OCS=30000

# Credential cache
CACHE_TTL_CREDENTIALS=30000

# =============================================================================
# HEARTBEAT MANAGER
# =============================================================================

# Heartbeat interval (ms) - how often to check for tasks
HEARTBEAT_INTERVAL=300000

# Quiet hours (24h format) - no notifications during these hours
QUIET_START=22
QUIET_END=7

# Max tasks to process per heartbeat cycle
HEARTBEAT_MAX_TASKS=3

# Calendar lookahead for upcoming events (minutes)
HEARTBEAT_CALENDAR_LOOKAHEAD=30

# Enable Deck task processing
HEARTBEAT_DECK_ENABLED=true

# Enable CalDAV calendar processing
HEARTBEAT_CALDAV_ENABLED=true

# =============================================================================
# EMAIL MONITOR
# =============================================================================

# Initial delay before first email check (ms)
EMAIL_MONITOR_INITIAL_DELAY=30000

# Email check interval (ms)
EMAIL_CHECK_INTERVAL=60000

# Max pending email notifications in queue
EMAIL_MAX_PENDING=10

# Time before notification is considered stale (ms)
EMAIL_STALE_NOTIFICATION=86400000

# Max processed email IDs to track (prevents reprocessing)
EMAIL_MAX_PROCESSED_IDS=1000

# =============================================================================
# DECK INTEGRATION
# =============================================================================

# Default Deck board ID
DECK_BOARD_ID=8

# Days before completed tasks are archived
DECK_ARCHIVE_AFTER_DAYS=180

# =============================================================================
# KNOWLEDGE (Collectives Wiki)
# =============================================================================

# Admin user to share the knowledge collective with (empty = no sharing)
# KNOWLEDGE_ADMIN_USER=your-admin-username

# =============================================================================
# LLM RESILIENCE
# =============================================================================

# Max tokens for LLM responses
LLM_MAX_TOKENS=1024

# Circuit breaker: failures before opening
LLM_CB_THRESHOLD=5

# Circuit breaker: time before retry (ms)
LLM_CB_RESET=60000

# Circuit breaker: successes needed to close
LLM_CB_SUCCESS=3

# Loop detector: time window (ms)
LLM_LOOP_WINDOW=60000

# Loop detector: max same calls before detected
LLM_LOOP_MAX_SAME=5

# Loop detector: max errors before detected
LLM_LOOP_MAX_ERRORS=3

# Loop detector: ping-pong threshold
LLM_LOOP_PINGPONG=4

# Backoff: initial delay (ms)
LLM_BACKOFF_INITIAL=1000

# Backoff: max delay (ms)
LLM_BACKOFF_MAX=300000

# Backoff: multiplier per attempt
LLM_BACKOFF_MULTIPLIER=2

# Backoff: max attempts before giving up
LLM_BACKOFF_MAX_ATTEMPTS=5

# =============================================================================
# PENDING ACTIONS (Human-in-the-Loop)
# =============================================================================

# Confirmation request expiry (ms)
PENDING_CONFIRMATION_TTL=300000

# Email reply expiry (ms)
PENDING_EMAIL_REPLY_TTL=1800000

# Cleanup interval for expired actions (ms)
PENDING_CLEANUP_INTERVAL=300000

# =============================================================================
# WEB SEARCH (SearXNG)
# =============================================================================

# SearXNG instance URL (required for web search tool)
SEARXNG_URL=http://localhost:8080

# Max results per search query
# SEARXNG_DEFAULT_LIMIT=5

# SearXNG request timeout (ms)
# SEARXNG_TIMEOUT=10000

# Default search engines (comma-separated, empty = all)
# SEARXNG_DEFAULT_ENGINES=

# Default search language
# SEARXNG_DEFAULT_LANGUAGE=en

# =============================================================================
# MEMORY SEARCH
# =============================================================================

# Enable memory search tool (keyword search over wiki pages)
MEMORY_SEARCH_ENABLED=true

# Search backend: 'keyword' (default) or 'semantic' (future)
# MEMORY_SEARCH_BACKEND=keyword

# =============================================================================
# ROOM MONITOR (instant welcome messages for new rooms)
# =============================================================================

# Enable room monitoring (detects new rooms, sends welcome/activation messages)
ROOM_MONITOR_ENABLED=true

# Room check interval (ms) — how often to poll for new rooms
ROOM_MONITOR_INTERVAL=60000

# =============================================================================
# NC STATUS INDICATOR
# =============================================================================

# Set Molti's NC user status based on real-time activity (Ready, Thinking, etc.)
STATUS_INDICATOR_ENABLED=true

# =============================================================================
# TESTING (do not use in production)
# =============================================================================

# TEST_NC_PASSWORDS=true
